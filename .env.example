# Database (lokaal Postgres tijdens ontwikkeling; Supabase later te koppelen)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/ashi_tashi?schema=public"

# Voice providers — NIET gebruikt in de MVP-mock, alleen voorbereid voor latere koppeling.
# Nooit in frontend-code plaatsen; alleen server-side gebruiken.
TTS_PROVIDER="mock"       # mock | elevenlabs | google | azure
TTS_API_KEY=""

PRONUNCIATION_PROVIDER="mock"  # mock | azure | google
PRONUNCIATION_API_KEY=""

# Feature flags (hfst. 37)
FEATURE_MICROPHONE_ENABLED="true"
FEATURE_OFFLINE_MODE="false"
